# Copy this file to .env for local testing (never commit your real .env).
# In production these are stored as GitHub Actions repository secrets instead.

# Telegram bot token from @BotFather (looks like 123456789:ABCdef...)
TELEGRAM_BOT_TOKEN=

# Your personal Telegram chat id from @userinfobot (a number, e.g. 12345678)
TELEGRAM_CHAT_ID=
